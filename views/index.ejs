<!DOCTYPE html>
<html lang="es">
<head>
    <%- include('partials/head') %>
    <title>Nova 2030</title>
</head>
<body>
    <div class = "page">

        <!--Llamada al sidebar-->
        <%- include('partials/sidenavbar') %>

        <!--Llamada al header-->
        <%- include('partials/header') %>

        
        
        <!--Contenido específico de la página actual-->
        <main class = "content">
            <div class="cards-container">
                <% submodulos.forEach(sub => { %>
                    <% include('partials/card-modulos', { sub: sub }) %>
                
                <% }) %>
            </div>
        </main>

        <!--Llamada al sidebar de anuncios-->
        <%- include('partials/sidebar-anuncios') %>

        <!--Llamada al footer-->
        <%- include('partials/footer') %>
        
    </div>
</body>
</html>