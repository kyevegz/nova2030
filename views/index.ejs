<!DOCTYPE html>
<html lang="es">
<head>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Momo+Trust+Display&family=Montserrat+Alternates:ital,wght@0,100;0,200;0,300;0,400;0,500;0,600;0,700;0,800;0,900;1,100;1,200;1,300;1,400;1,500;1,600;1,700;1,800;1,900&family=Nunito:ital,wght@0,200..1000;1,200..1000&display=swap" rel="stylesheet">
    <script src="https://kit.fontawesome.com/034afea5da.js" crossorigin="anonymous"></script>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel = "stylesheet" href="/css/style.css">
    <script src = "/js/main.js" defer></script>
    <title>Nova 2030</title>
</head>
<body>
    <div class = "page">

        <!--Llamada al sidebar-->
        <%- include('partials/sidenavbar') %>

        <!--Llamada al header-->
        <%- include('partials/header') %>

        
        
        <!--Contenido específico de la página actual-->
        <main class = "content">
            <div class="cards-container">
                <% submodulos.forEach(sub => { %>
                    
                <article class = "card <%= sub.desbloqueado === 0 ? 'card--block' : '' %>">
                    <header class = "card__header <%= sub.desbloqueado === 0 ? 'card__header--block' : '' %>">
                        <h3 class = "card__title <%= sub.desbloqueado === 0 ? 'card__title--block' : '' %>">
                            <!-- Cuestionario inicial   -->
                            <%= sub.titulo  %>
                        </h3>
                        <i class = "card__icon fa-solid <%= sub.desbloqueado === 0 ? 'fa-lock card__icon--block' : sub.rutaIcono %>" aria-label=""></i>
                    </header>
                    <p class = "card__description">
                        <!-- Analiza el punto de dónde partes, qué es lo que sabes y lo que te falta. -->
                        <%= sub.descripcion %>
                    </p>
                    <button class="card__button <%= sub.desbloqueado === 0 ? 'card__button--block' : '' %>">
                        <p class="card__button-text">
                            <%= sub.desbloqueado === 1 ? 'Ir' : 'Bloqueado' %>
                        </p> 
                        <i class="fa-solid <%= sub.desbloqueado === 0 ? 'fa-lock' : 'fa-right-long' %>" aria-hidden="true"></i>
                    </button>
                </article> 
                <% }) %>
            </div>
        </main>

        <aside class = "sidebar sidebar--ads">
            sidebar anuncios
        </aside>

        <!--Llamada al footer-->
        <%- include('partials/footer') %>
        
    </div>
</body>
</html>